# Required in deployed environments to authorize run-control endpoints/tools.
RESEARCH_RUN_TOKEN=replace-with-strong-random-token

# Optional hard read-only switch for any deployment environment.
# true/1/yes/on forces hosted and local API run controls off.
RESEARCH_READ_ONLY=

# Hosted opt-in: when deploying on Vercel, run controls are read-only by default.
# Set true/1/yes/on only on forks you control if you intentionally want hosted compute.
RESEARCH_ENABLE_HOSTED_RUNS=

# Optional: only needed if browser UI should invoke protected legacy run routes.
# This value is bundled client-side; do not use a sensitive long-lived token.
NEXT_PUBLIC_RESEARCH_RUN_TOKEN=

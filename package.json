{
  "name": "riemann-converter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 7000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "analyze": "python -m analyzer --out reports/latest.md",
    "test:js": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "test:py": "python -m pytest tests",
    "test": "npm run test:js && npm run test:py",
    "typecheck": "tsc --noEmit",
    "reset:artifacts": "python scripts/reset_artifacts.py"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^0.564.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jest": "^30.2.0",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
